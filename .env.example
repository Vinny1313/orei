# Supabase — copie este arquivo para `.env` (ou `.env.local`) e preencha com as chaves
# do seu projeto. Encontre-as em: Supabase Dashboard → Project Settings → API.
#
# Sem estes valores, o app roda em "modo visitante" durante o desenvolvimento (npm run dev).
# Em produção (build), a ausência das chaves bloqueia o acesso e a tela de login avisa.
#
# NUNCA commite o `.env` real — apenas este `.env.example`.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
